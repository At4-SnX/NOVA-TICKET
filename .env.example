# Copie ce fichier en ".env" en local, ou configure ces variables
# directement dans l'onglet "Variables" de ton service Railway.
# NE JAMAIS commit le fichier .env réel sur GitHub.

# ─── Discord ───────────────────────────────────────────────
DISCORD_TOKEN=ton_token_discord_ici

# ─── Personnalisation ───────────────────────────────────────
# Nom affiché dans les titres d'embed ("Bienvenue sur le support de ...")
SERVER_NAME=NOVA RP

# Couleur des embeds (code hexadécimal)
THEME_COLOR=#5865F2

# Commande tapée dans un salon pour envoyer le panneau de tickets
# (réservée aux administrateurs du serveur)
PANEL_COMMAND=!sendpanel

# ─── Rôles ──────────────────────────────────────────────────
# Rôle considéré comme "staff" : peut claim/lock/fermer les tickets,
# et reçoit les tickets par défaut si aucun rôle de ping spécifique
# n'est défini pour une catégorie.
STAFF_ROLE_ID=id_du_role_staff

# Salon où sont envoyés les transcripts des tickets fermés
LOG_CHANNEL_ID=id_du_salon_logs

# ─── Rôles à ping selon le type de ticket ───────────────────
# Optionnels : si non définis, STAFF_ROLE_ID est utilisé par défaut.
PING_ROLE_UNBAN_ID=id_role_unban
PING_ROLE_LEGAL_ID=id_role_legal
PING_ROLE_ILLEGAL_ID=id_role_illegal
PING_ROLE_REPORTSTAFF_ID=id_role_reportstaff
PING_ROLE_PARTENARIAT_ID=id_role_partenariat

# ─── Catégories (obligatoires) ───────────────────────────────
# ID de la catégorie Discord dans laquelle chaque type de ticket est créé.
# Chacune doit être une catégorie DIFFÉRENTE si tu veux les séparer
# (le bot d'origine avait un bug où "unban" et "question" partageaient
# accidentellement le même ID — vérifie bien que chaque valeur ci-dessous
# est unique et correcte).
CATEGORY_QUESTION_ID=id_categorie_question
CATEGORY_PARTENARIAT_ID=id_categorie_partenariat
CATEGORY_REPORTSTAFF_ID=id_categorie_reportstaff
CATEGORY_REPORTJOUEUR_ID=id_categorie_reportjoueur
CATEGORY_LEGAL_ID=id_categorie_legal
CATEGORY_ILLEGAL_ID=id_categorie_illegal
CATEGORY_FONDATION_ID=id_categorie_fondation
CATEGORY_UNBAN_ID=id_categorie_unban
